// Tool Cards frontend extension.
//
// Queries the toolcards server plugin for installed cards and registers
// each declared tool as an OpenAI-style function tool via SillyTavern's
// ToolManager. Sessions are server-authoritative: at /start_invoke time
// the FE snapshots the user's chat-completion profile and the chat_id,
// and the plugin handles llm_call dispatch + lifecycle internally. The
// FE's role is reduced to:
//
//   1. POST /start_invoke with {args, profile, chat_id, caller_message_id}
//        → {session_id}
//   2. (cosmetic) long-poll /poll/<session_id> for live progress events
//        - progress event: append status line to caller's tool_progress entry
//        - heartbeat: continue
//        - result event: splice embed via the marker pipeline, finalize
//   3. On visibilitychange, reconcile via GET /sessions?chat_id=X for
//      results that completed while we weren't polling.
//
// If the poll loop dies (mobile suspend, network blip), the session
// continues server-side and we'll pick up the result on next reconcile.

import { oai_settings } from '../../openai.js';
import { getRequestHeaders } from '../../../script.js';

const PLUGIN_BASE = '/api/plugins/toolcards';

const $ = (s, root = document) => root.querySelector(s);

async function fetchJson(url, opts = {}) {
    // Merge ST's standard request headers (CSRF token, session cookies,
    // etc.) with any caller-supplied headers. ST's CSRF middleware
    // returns HTML 403 if the token is missing — even on plugin routes.
    const stHeaders = getRequestHeaders();
    const merged = {
        ...opts,
        headers: { ...stHeaders, ...(opts.headers || {}) },
    };
    const res = await fetch(url, merged);
    if (!res.ok) {
        const body = await res.text().catch(() => '');
        throw new Error(`${url} → ${res.status}: ${body.slice(0, 300)}`);
    }
    return await res.json();
}

async function listCards() {
    const data = await fetchJson(PLUGIN_BASE + '/list');
    return data.cards || [];
}

/**
 * Snapshot the user's chat-completion profile at session-start time.
 * The plugin uses this to dispatch llm_call events server-side, so the
 * tool keeps running even if this tab dies or suspends. Decision is
 * fixed at session start; changing the active model mid-tool-call still
 * uses the original profile (predictable semantics).
 */
function snapshotProfile() {
    return {
        chat_completion_source: oai_settings.chat_completion_source,
        openai_model: oai_settings.openai_model,
        model: oai_settings.openai_model || oai_settings.model,
        custom_url: oai_settings.custom_url,
        reverse_proxy: oai_settings.reverse_proxy,
        proxy_password: oai_settings.proxy_password,
        custom_prompt_post_processing: oai_settings.custom_prompt_post_processing,
        temperature: oai_settings.temp_openai ?? 0.7,
    };
}

/**
 * Get a stable identifier for the current chat. Used as the key the
 * plugin stores per-chat result queues under, so this tab can pick up
 * results that completed while it was suspended/refreshed.
 */
function currentChatId() {
    try {
        const ctx = SillyTavern.getContext();
        return ctx.chatId || ctx.getCurrentChatId?.() || ctx.chat_metadata?.chat_id_hash || null;
    } catch (_) { return null; }
}

async function invokeToolViaSession(cardId, toolName, args, label, callerCtx) {
    // Snapshot profile + chat metadata at session start. The plugin
    // dispatches llm_call events server-side using these, so the tool
    // continues to run even if this tab is suspended or closed.
    const startResp = await fetchJson(
        `${PLUGIN_BASE}/start_invoke/${encodeURIComponent(cardId)}/${encodeURIComponent(toolName)}`,
        {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({
                args: args || {},
                profile: snapshotProfile(),
                chat_id: currentChatId(),
                caller_message_id: callerCtx?.idx ?? null,
            }),
        });
    const sessionId = startResp.session_id;
    if (!sessionId) throw new Error(startResp.error || 'failed to start invocation');

    // Attach a live progress entry to the caller assistant message. No
    // separate is_system bubble is created; the entry lives in
    // callerMsg.extra.tool_progress[] and is rendered inline by
    // messageFormatting (see script.js).
    const ph = attachToCallerMessage(callerCtx, label, sessionId);
    ph.sessionId = sessionId;
    ph.append(`session ${sessionId.slice(0, 8)} started`);
    // Track the live session so reconcile-on-resume can dedupe.
    liveSessions.set(sessionId, { ph, cardId, toolName, label });

    // Drive the cosmetic-progress poll loop. The plugin does the actual
    // llm_call dispatching server-side, so a failed poll loop is no
    // longer fatal — the session keeps running and we'll pick up the
    // result either when the loop recovers OR via /sessions reconcile
    // on visibilitychange. We retry transient failures and bail only
    // when we've gone too long without making progress.
    const POLL_RETRY_DELAYS_MS = [500, 1500, 5000, 15000];
    let consecutiveFailures = 0;
    try {
        while (true) {
            let event;
            try {
                event = await fetchJson(`${PLUGIN_BASE}/poll/${encodeURIComponent(sessionId)}`);
                consecutiveFailures = 0;
            } catch (e) {
                // Network blip / suspend / 404. If the session is gone
                // (404), we may have already received the result via
                // /sessions reconcile — bail and let that path drive.
                if (String(e?.message || '').includes('404')) {
                    ph.append('session not found server-side; awaiting reconcile');
                    return null;
                }
                consecutiveFailures += 1;
                if (consecutiveFailures > POLL_RETRY_DELAYS_MS.length) {
                    ph.append(`poll loop giving up after ${consecutiveFailures} failures; tool continues server-side`);
                    return null; // server-side session keeps running
                }
                const delay = POLL_RETRY_DELAYS_MS[Math.min(consecutiveFailures - 1, POLL_RETRY_DELAYS_MS.length - 1)];
                await new Promise(r => setTimeout(r, delay));
                continue;
            }
            if (event.type === 'heartbeat') continue;
            if (event.type === 'progress') {
                ph.append(typeof event.text === 'string' ? event.text : JSON.stringify(event));
                continue;
            }
            if (event.type === 'branch_progress') {
                ph.branchUpdate(event);
                continue;
            }
            if (event.type === 'result') {
                liveSessions.delete(sessionId);
                if (!event.ok) {
                    ph.fail(event.error || 'tool call failed');
                    throw new Error(event.error || 'tool call failed');
                }
                const r = event.result;
                ph.finalize(r && typeof r.summary === 'string' ? r.summary : null,
                            (r && Array.isArray(r.embed)) ? r.embed : null);
                return r;
            }
            // llm_call events are no longer routed to the FE since the
            // plugin dispatches them server-side. If we ever see one
            // (legacy server, missing profile in start_invoke body), log
            // it and ignore — the session will eventually time out.
            if (event.type === 'llm_call') {
                console.warn('[toolcards] received llm_call event from legacy server; server-side dispatch was expected');
                continue;
            }
            console.warn('[toolcards] unknown event type:', event.type);
        }
    } catch (err) {
        liveSessions.delete(sessionId);
        ph.fail(String(err?.message || err));
        throw err;
    }
}

/**
 * Reconcile completed sessions for the current chat that we may have
 * missed while suspended/refreshed. Called on visibilitychange and on
 * chat-load.
 */
const _appliedSessionIds = new Set();
async function reconcileSessions() {
    const chatId = currentChatId();
    if (!chatId) return;
    let payload;
    try {
        payload = await fetchJson(
            `${PLUGIN_BASE}/sessions?chat_id=${encodeURIComponent(chatId)}`,
        );
    } catch (e) {
        // Plugin not ready, network blip, etc — skip silently.
        return;
    }
    const ctx = SillyTavern.getContext();
    for (const r of payload.results || []) {
        if (_appliedSessionIds.has(r.session_id)) continue;
        _appliedSessionIds.add(r.session_id);
        // If we have a live ph for this session (the poll loop is still
        // running), let the loop apply the result. Otherwise apply now.
        if (liveSessions.has(r.session_id)) continue;
        // Find the caller assistant message by the captured index. If
        // the index moved (chat truncated, swiped, etc), fall back to
        // most-recent non-system assistant message.
        let callerMsg = null, callerIdx = -1;
        if (typeof r.caller_message_id === 'number' && ctx.chat[r.caller_message_id]) {
            callerMsg = ctx.chat[r.caller_message_id];
            callerIdx = r.caller_message_id;
        } else {
            const found = findCallerAssistantMessage(ctx);
            if (found) { callerMsg = found.msg; callerIdx = found.idx; }
        }
        if (!callerMsg) continue;
        // Synthesize an attachToCallerMessage-shaped progress entry so
        // the same finalize logic applies. We don't have the live label,
        // use a minimal one. If a partial entry already exists for this
        // session, prefer to update it rather than appending.
        const ph = attachToCallerMessage(
            { msg: callerMsg, idx: callerIdx },
            `${r.card_id} • ${r.tool_name}`);
        if (r.ok) {
            const result = r.result || {};
            ph.finalize(typeof result.summary === 'string' ? result.summary : null,
                        Array.isArray(result.embed) ? result.embed : null);
        } else {
            ph.fail(r.error || 'tool failed (reconciled after disconnect)');
        }
    }
}

// Track live sessions so reconcile knows what's already being driven.
const liveSessions = new Map(); // session_id → {ph, cardId, toolName, label}

// Run reconcile when the tab regains focus (mobile resume, alt-tab back).
if (typeof document !== 'undefined') {
    document.addEventListener('visibilitychange', () => {
        if (document.visibilityState === 'visible') {
            reconcileSessions().catch(() => { /* swallow */ });
        }
    });
}

async function installCard(cardJson) {
    const data = await fetchJson(PLUGIN_BASE + '/install', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(cardJson),
    });
    return data;
}

async function uninstallCard(cardId) {
    const data = await fetchJson(`${PLUGIN_BASE}/uninstall/${encodeURIComponent(cardId)}`, {
        method: 'POST',
    });
    return data;
}

// ── Tool registration ─────────────────────────────────────────────────

const registered = new Map(); // qualified_name → cardId (so we can re-register on reinstall)

function makeMarker() {
    const id = (typeof crypto !== 'undefined' && crypto.randomUUID)
        ? crypto.randomUUID() : Math.random().toString(36).slice(2);
    return `[[image:${id}]]`;
}

// Number of trailing lines from the live model output to render in the
// placeholder bubble's collapsed view. Full transcript is always
// available behind a <details>/<summary> expander.
const STREAM_TAIL_LINES = 3;

// Throttle live-stream re-renders so we're not thrashing the DOM at
// every token. 80ms ≈ 12 FPS, plenty for "live text" feel without
// torching the renderer.
const STREAM_RENDER_INTERVAL_MS = 80;

/**
 * Locate the calling assistant message in chat[]. Generation is serialized,
 * so the most-recent non-system, non-user message is the one that emitted
 * the tool_call we're servicing. Returns {msg, idx} or null if not found.
 *
 * (We could use the threaded {id, toolCall} from the action's opts to
 * disambiguate further if there were ever concurrent invocations, but the
 * tool-calling pipeline is sequential — see ToolManager.invokeFunctionTools.)
 */
function findCallerAssistantMessage(ctx) {
    for (let i = ctx.chat.length - 1; i >= 0; i--) {
        const m = ctx.chat[i];
        if (!m || m.is_system || m.is_user) continue;
        return { msg: m, idx: i };
    }
    return null;
}

/**
 * Attach a live tool-progress entry to the caller assistant message and
 * return helpers to mutate it as the card progresses.
 *
 *   - append(text)            terse status line
 *   - streamText(scope, full) live raw model output for an in-flight LLM
 *                             call (sub-LLM dispatched by the card)
 *   - streamDone(scope)       mark a streaming scope finished
 *   - branchUpdate(event)     update per-branch progress for Shape-D cards
 *   - finalize(summary, embed) snap the entry to "done", append inline
 *                              media markers + extra.media entries for any
 *                              image_url parts in `embed` so the model
 *                              sees them on the next round-trip
 *   - fail(text)              snap the entry to "failed"
 *
 * No separate is_system bubble is created. The progress entry lives in
 * caller.extra.tool_progress[] and is rendered inline by messageFormatting.
 */
function attachToCallerMessage(callerCtx, label, sessionId = null) {
    const ctx = SillyTavern.getContext();
    let owner = callerCtx;
    // Late-bind: if the action callback wasn't able to find a caller at
    // dispatch time (rare — would imply chat[] was empty), retry now.
    if (!owner || !owner.msg) owner = findCallerAssistantMessage(ctx);
    if (!owner || !owner.msg) {
        // Catastrophic fallback: chat is genuinely empty. Push a synthetic
        // system message just so progress is visible somewhere. Should
        // basically never fire in practice.
        const stub = {
            name: 'Tool', is_system: true, is_user: false,
            send_date: new Date().toLocaleString(),
            mes: '', extra: { tool_progress: [] },
        };
        ctx.chat.push(stub);
        owner = { msg: stub, idx: ctx.chat.length - 1 };
        try { ctx.addOneMessage(stub); } catch (_) { /* ignore */ }
    }
    const msg = owner.msg;
    const messageId = owner.idx;
    if (!msg.extra || typeof msg.extra !== 'object') msg.extra = {};
    if (!Array.isArray(msg.extra.tool_progress)) msg.extra.tool_progress = [];

    const entry = {
        label,
        status: 'running',
        started_at: Date.now(),
        status_lines: [],
        transcript: [],
        done: false,
    };
    if (typeof sessionId === 'string' && sessionId.length) {
        entry.session_id = sessionId;
    }
    msg.extra.tool_progress.push(entry);

    let lastRender = 0;
    function rerender(force = false) {
        const now = Date.now();
        if (!force && (now - lastRender) < STREAM_RENDER_INTERVAL_MS) return;
        lastRender = now;
        try { ctx.updateMessageBlock(messageId, msg); }
        catch (e) { console.warn('[toolcards] updateMessageBlock failed:', e); }
    }

    function append(text) {
        if (typeof text !== 'string') return;
        entry.status_lines.push(text);
        rerender(true);
    }

    function streamText(scope, fullText) {
        if (typeof fullText !== 'string') return;
        let last = entry.transcript[entry.transcript.length - 1];
        if (!last || last.scope !== scope || last.done) {
            last = { scope: scope || '', text: '', done: false };
            entry.transcript.push(last);
        }
        last.text = fullText;
        rerender();
    }

    function streamDone(scope) {
        for (let i = entry.transcript.length - 1; i >= 0; i--) {
            if (entry.transcript[i].scope === scope && !entry.transcript[i].done) {
                entry.transcript[i].done = true;
                break;
            }
        }
        rerender(true);
    }

    function branchUpdate(event) {
        const branchIndex = Number(event?.branch_index);
        if (!Number.isInteger(branchIndex) || branchIndex < 0) return;
        if (!Array.isArray(entry.branches)) entry.branches = [];

        const current = entry.branches[branchIndex] || {};
        const label = typeof event.branch_label === 'string'
            ? event.branch_label
            : (typeof current.label === 'string' ? current.label : `branch ${branchIndex + 1}`);
        if (event.status === 'started') {
            entry.branches[branchIndex] = {
                ...current,
                label,
                status: 'running',
            };
        } else if (event.status === 'complete') {
            entry.branches[branchIndex] = {
                ...current,
                label,
                status: 'complete',
                summary: typeof event.summary === 'string' ? event.summary : '',
                reasoning: typeof event.reasoning === 'string' ? event.reasoning : '',
            };
        } else {
            entry.branches[branchIndex] = {
                ...current,
                label,
                status: typeof event.status === 'string' ? event.status : (current.status || 'running'),
            };
        }
        rerender(true);
    }

    function finalize(summary, embed) {
        entry.status = 'done';
        entry.done = true;
        entry.session_id = null;
        entry.duration_ms = Date.now() - entry.started_at;
        if (typeof summary === 'string' && summary.length) entry.summary = summary;
        for (const t of entry.transcript) t.done = true;

        // Splice inline media into the caller message: append marker +
        // extra.media entry for each image_url part in embed. The
        // existing inline-media pipeline (script.js#messageFormatting +
        // openai.js#populateChatHistory#inlineMediaAttachment) handles
        // both the chat-surface render and the model-context injection
        // from here.
        if (Array.isArray(embed) && embed.length) {
            if (!Array.isArray(msg.extra.media)) msg.extra.media = [];
            const tail = [];
            for (const part of embed) {
                if (!part || typeof part !== 'object') continue;
                if (part.type === 'image_url' && part.image_url && typeof part.image_url.url === 'string') {
                    const marker = makeMarker();
                    tail.push(marker);
                    msg.extra.media.push({
                        url: part.image_url.url,
                        type: 'image',
                        title: label,
                        marker,
                        source: 'tool',
                    });
                }
                // Note: text parts in embed are intentionally NOT spliced
                // into msg.mes here — the model already gets the textual
                // summary via the action callback's return value (which
                // becomes the role:"tool" content). Splicing text would
                // double-emit. If a card wants prose visible inline, it
                // can include a text-only paragraph in the summary.
            }
            if (tail.length) {
                msg.mes = (typeof msg.mes === 'string' ? msg.mes : '') +
                          (msg.mes && msg.mes.length ? '\n\n' : '') + tail.join('');
            }
        }

        lastRender = 0;
        rerender(true);
        if (typeof ctx.saveChat === 'function') {
            ctx.saveChat().catch(e => console.warn('[toolcards] saveChat failed:', e));
        }
    }

    function fail(text) {
        entry.status = 'failed';
        entry.done = true;
        entry.session_id = null;
        entry.duration_ms = Date.now() - entry.started_at;
        entry.error = String(text || '');
        for (const t of entry.transcript) t.done = true;
        lastRender = 0;
        rerender(true);
        if (typeof ctx.saveChat === 'function') {
            ctx.saveChat().catch(() => {});
        }
    }

    return { messageId, msg, append, streamText, streamDone, branchUpdate, finalize, fail };
}

function registerOneTool(card, tool) {
    const ctx = SillyTavern.getContext();
    const qualifiedName = `${card.id}__${tool.name}`;
    const displayName = `${card.display_name} • ${tool.display_name ?? tool.name}`;
    ctx.registerFunctionTool({
        name: qualifiedName,
        displayName,
        description: tool.description,
        parameters: tool.parameters,
        // ToolManager passes (parameters, opts={id, toolCall}) — the second
        // arg is forwarded by tool-calling.js#invokeFunctionTool as of the
        // tool_call_id-threading patch. Older callers passed only args, so
        // opts may be undefined; default to {}.
        action: async (args, opts = {}) => {
            const label = `${card.display_name} • ${tool.display_name ?? tool.name}`;
            // Resolve the caller assistant message at dispatch time. The
            // tool-progress entry and any inline image embeds will live on
            // this message's extra (rendered by messageFormatting).
            const callerCtx = findCallerAssistantMessage(ctx);
            const result = await invokeToolViaSession(card.id, tool.name, args, label, callerCtx);
            // The model sees ONLY this textual summary in its role:"tool"
            // content. The image (if any) was spliced into the caller
            // assistant message by attachToCallerMessage's finalize via the
            // marker + extra.media pipeline; the OAI prompt builder picks
            // it up from there as an image_url content part.
            if (result && typeof result === 'object') {
                if (typeof result.summary === 'string') return result.summary;
                const { embed: _, ...lean } = result;
                return JSON.stringify(lean);
            }
            if (typeof result === 'string') return result;
            return JSON.stringify(result);
        },
        formatMessage: async (args) => {
            return `Calling ${displayName} with ${JSON.stringify(args)}`;
        },
        stealth: false,
    });
    registered.set(qualifiedName, card.id);
}

async function refreshTools() {
    const cards = await listCards();
    const ctx = SillyTavern.getContext();
    // Naive: unregister everything we previously registered, then re-register.
    for (const qn of [...registered.keys()]) {
        try { ctx.unregisterFunctionTool(qn); } catch (_) { /* fine */ }
        registered.delete(qn);
    }
    for (const card of cards) {
        for (const tool of card.tools) {
            registerOneTool(card, tool);
        }
    }
    console.log(`[toolcards] registered ${registered.size} tool(s) from ${cards.length} card(s)`);
    return cards;
}

// ── UI panel ──────────────────────────────────────────────────────────

const PANEL_HTML = `
<div id="toolcards_settings_block" class="extension_settings">
    <div class="inline-drawer">
        <div class="inline-drawer-toggle inline-drawer-header">
            <b>Tool Cards</b>
            <div class="inline-drawer-icon fa-solid fa-circle-chevron-down down"></div>
        </div>
        <div class="inline-drawer-content">
            <div style="display:flex; gap:0.5em; align-items:center; flex-wrap:wrap;">
                <input type="file" id="toolcards_install_input" accept=".json,application/json" style="display:none">
                <input type="button" id="toolcards_install_btn" class="menu_button" value="Install card from .toolcard.json…">
                <input type="button" id="toolcards_refresh_btn" class="menu_button" value="Refresh">
            </div>
            <div id="toolcards_list" style="margin-top:0.5em; display:flex; flex-direction:column; gap:0.25em;"></div>
            <small style="opacity:0.6;">Cards spawn Python subprocesses with full filesystem and network access. Audit before installing — see docs/TOOLCARDS.md.</small>
        </div>
    </div>
</div>
`;

function renderList(cards) {
    const list = $('#toolcards_list');
    if (!list) return;
    list.innerHTML = '';
    if (!cards.length) {
        list.innerHTML = '<i style="opacity:0.6">No cards installed.</i>';
        return;
    }
    for (const c of cards) {
        const row = document.createElement('div');
        row.style.cssText = 'border:1px solid var(--SmartThemeBorderColor); padding:0.4em 0.6em; border-radius:4px;';
        const header = document.createElement('div');
        header.style.cssText = 'display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:0.5em;';
        header.innerHTML = `<span><b>${escapeHtml(c.display_name)}</b> <code style="opacity:0.7">${escapeHtml(c.id)}</code> <small>v${escapeHtml(c.version)}</small></span>`;
        const rmBtn = document.createElement('input');
        rmBtn.type = 'button';
        rmBtn.className = 'menu_button';
        rmBtn.value = 'Uninstall';
        rmBtn.addEventListener('click', async () => {
            if (!confirm(`Uninstall "${c.display_name}"?`)) return;
            try {
                await uninstallCard(c.id);
                await refreshTools();
                renderList(await listCards());
            } catch (e) { alert(`Uninstall failed: ${e.message}`); }
        });
        header.appendChild(rmBtn);
        row.appendChild(header);
        const desc = document.createElement('div');
        desc.style.cssText = 'opacity:0.85; font-size:0.9em; margin-top:0.2em;';
        desc.textContent = c.description;
        row.appendChild(desc);
        const tools = document.createElement('div');
        tools.style.cssText = 'opacity:0.7; font-size:0.85em; margin-top:0.2em;';
        tools.textContent = `Tools: ${c.tools.map(t => t.qualified_name).join(', ')}`;
        row.appendChild(tools);
        list.appendChild(row);
    }
}

function escapeHtml(s) {
    return String(s).replace(/[&<>"']/g, c => ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c]));
}

async function setupUI() {
    const host = $('#extensions_settings2') || $('#extensions_settings');
    if (!host) return;
    const wrapper = document.createElement('div');
    wrapper.innerHTML = PANEL_HTML;
    host.appendChild(wrapper);

    const fileInput = $('#toolcards_install_input');
    $('#toolcards_install_btn').addEventListener('click', () => fileInput.click());
    fileInput.addEventListener('change', async () => {
        const file = fileInput.files?.[0];
        if (!file) return;
        try {
            const text = await file.text();
            const card = JSON.parse(text);
            const result = await installCard(card);
            if (result.errors) {
                alert(`Install failed:\n- ${result.errors.join('\n- ')}`);
            } else {
                await refreshTools();
                renderList(await listCards());
            }
        } catch (e) {
            alert(`Install failed: ${e.message}`);
        } finally {
            fileInput.value = '';
        }
    });
    $('#toolcards_refresh_btn').addEventListener('click', async () => {
        try {
            await refreshTools();
            renderList(await listCards());
        } catch (e) { alert(`Refresh failed: ${e.message}`); }
    });

    try {
        const cards = await refreshTools();
        renderList(cards);
    } catch (e) {
        console.warn('[toolcards] initial refresh failed:', e.message);
        renderList([]);
    }
}

jQuery(async () => {
    await setupUI();
    // Initial reconcile in case the page was reloaded mid-tool-call. The
    // chat may have already been loaded; results that completed
    // server-side while we were gone get spliced onto their caller
    // bubbles via the same finalize path the live poll loop uses.
    reconcileSessions().catch(() => { /* swallow — plugin may not be ready */ });

    // Delegated click handler for the cancel link rendered inside the
    // tool_progress collapsibles in messageFormatting (script.js). The
    // link carries data-cancel-session-id; we use a data-attr because
    // DOMPurify strips inline onclick handlers (event.preventDefault
    // etc are silently dropped during sanitization). The class gets
    // `custom-` prefixed by ST's DOMPurify hook.
    jQuery(document).on('click', '.custom-tool-progress-cancel, .tool-progress-cancel', function (e) {
        e.preventDefault();
        e.stopPropagation();
        const sessionId = this.getAttribute('data-cancel-session-id');
        if (sessionId) cancelToolSession(sessionId);
    });
});

// Expose a global cancel helper so a UI button on the in-progress
// collapsible can call it. Wires through to /cancel/:session_id.
async function cancelToolSession(sessionId) {
    if (!sessionId) return;
    try {
        await fetchJson(`${PLUGIN_BASE}/cancel/${encodeURIComponent(sessionId)}`,
            { method: 'POST' });
    } catch (e) {
        console.warn('[toolcards] cancel failed:', e?.message || e);
    }
}
window.toolcardsCancelSession = cancelToolSession;
