# Demo captures written by tetraplex_recorder. Specific recordings that
# are embedded in docs/ live at docs/media/ and are tracked there — the
# general-ignore below only applies to the ad-hoc capture directory.
/recordings/

# Python bridge
server/__pycache__/
server/.venv/
__pycache__/
*.pyc

# macOS
.DS_Store

# Python venv (lives under test_data/reference/)
test_data/**/.venv/
test_data/**/__pycache__/

# Oracle / validation .npy files — regenerate via test_data/reference/extract_*.py
# scripts; too large for git (vision_soft_tokens.npy alone is 605 MB).
test_data/**/*.npy
test_data/**/*.bin

# Misc build artifacts
*.dSYM/

# Working design notes — unpublished, pre-implementation thinking.
# Promoted files graduate to docs/ once the mechanism is validated.
/notes/

# Experimental output: ad-hoc benchmark runs, perf probes, harness comparison
# results. Use this dir instead of /tmp so external validation tools, render
# inspection, and historical comparison are available across sessions.
/output_data/

# Bridge stdout/stderr logs (live forensic record across runs;
# moved out of /tmp/ post-2026-05-06 macOS-watchdog crash so they
# survive system reboots. Per-launch timestamped files.
bridge-logs/
study-records/
study-logs/
/.claude/
